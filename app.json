{
  "expo": {
    "name": "JejuFlow",
    "slug": "jejuflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2A12"
    },
    "scheme": "jejuflow",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jejuflow.app",
      "config": {
        "googleMapsApiKey": "$(EXPO_PUBLIC_GOOGLE_MAPS_KEY)"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "JejuFlow uses your location to find nearby bus stops and recommend spots based on where you are in Jeju."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F2A12"
      },
      "package": "com.jejuflow.app",
      "config": {
        "googleMaps": {
          "apiKey": "$(EXPO_PUBLIC_GOOGLE_MAPS_KEY)"
        }
      },
      "permissions": ["ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
